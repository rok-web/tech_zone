<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ page_title }} — {{ shop.name }}</title>
  <meta name="description" content="{{ page_description | escape }}">

  {{ content_for_header }}

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600;700&family=Playfair+Display:wght@700;900&display=swap" rel="stylesheet">

  {{ 'style.css' | asset_url | stylesheet_tag }}
</head>
<body>

  <!-- ANNOUNCEMENT BAR -->
  <div class="announce-bar">
    <div class="announce-track">
      <div class="announce-content">
        Same Day Delivery in Hyderabad &nbsp;<span>|</span>&nbsp; Open Box Delivery &nbsp;<span>|</span>&nbsp; COD Available &nbsp;<span>|</span>&nbsp; Rs.99 Token — 100% Refundable &nbsp;<span>|</span>&nbsp; 500+ Orders Delivered
      </div>
      <div class="announce-content">
        Same Day Delivery in Hyderabad &nbsp;<span>|</span>&nbsp; Open Box Delivery &nbsp;<span>|</span>&nbsp; COD Available &nbsp;<span>|</span>&nbsp; Rs.99 Token — 100% Refundable &nbsp;<span>|</span>&nbsp; 500+ Orders Delivered
      </div>
    </div>
  </div>

  <!-- NAVBAR -->
  <nav>
    <a href="{{ shop.url }}" class="nav-logo">
      <div class="nav-logo-dot">TZ</div>
      {{ shop.name | upcase }}
    </a>
    <div class="nav-links">
      {% for link in linklists.main-menu.links %}
        <a href="{{ link.url }}" {% if link.active %}class="active"{% endif %}>{{ link.title }}</a>
      {% endfor %}
    </div>

    <div class="nav-actions">
      <a href="#order" class="nav-cta">Order Now</a>
      <button class="mobile-menu-toggle" id="menuToggle" aria-label="Toggle menu">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </nav>

  <!-- MOBILE MENU DRAWER -->
  <div class="mobile-drawer" id="mobileDrawer">
    <div class="drawer-header">
      <div class="nav-logo">
        <div class="nav-logo-dot">TZ</div>
        {{ shop.name | upcase }}
      </div>
      <button class="drawer-close" id="drawerClose">&times;</button>
    </div>
    <div class="drawer-links">
      {% for link in linklists.main-menu.links %}
        <a href="{{ link.url }}" {% if link.active %}class="active"{% endif %}>
          {{ link.title }}
          <span class="arrow">→</span>
        </a>
      {% endfor %}
    </div>
    <div class="drawer-footer">
      <a href="#order" class="btn-primary drawer-cta">Order Now</a>
      <div class="drawer-social">
        Hyderabad's Most Trusted Local Store
      </div>
    </div>
  </div>
  <div class="drawer-overlay" id="drawerOverlay"></div>

  <main role="main">
    {{ content_for_layout }}
  </main>

  <!-- FOOTER -->
  <footer>
    <div class="footer-inner">
      <div class="footer-brand">
        <div class="nav-logo">
          <div class="nav-logo-dot">TZ</div>
          {{ shop.name | upcase }}
        </div>
        <p>{{ shop.description | default: "Hyderabad's most trusted local gadget store. Same-day delivery. Open box. COD. Based in Secunderabad since 2024." }}</p>
      </div>
      <div class="footer-col">
        <h4>Products</h4>
        <a href="#">AirPods &amp; Earbuds</a>
        <a href="#">Smartwatches</a>
        <a href="#">Power Banks</a>
        <a href="#">Neckbands</a>
        <a href="#">Accessories</a>
      </div>
      <div class="footer-col">
        <h4>Support</h4>
        <a href="#">WhatsApp Us</a>
        <a href="#">Track Order</a>
        <a href="#">Return Policy</a>
        <a href="#">Warranty</a>
        <a href="#">FAQ</a>
      </div>
      <div class="footer-col">
        <h4>Company</h4>
        <a href="{{ shop.url }}/pages/about">About Us</a>
        <a href="#">Instagram</a>
        <a href="#">Reviews</a>
        <a href="{{ shop.url }}/pages/contact">Contact</a>
        <a href="{{ shop.url }}/policies/privacy-policy">Privacy Policy</a>
      </div>
    </div>
    <div class="footer-bottom">
      <div>© {{ 'now' | date: '%Y' }} {{ shop.name }} · Secunderabad, Telangana</div>
      <div>Secure · Open Box · Same Day · COD</div>
    </div>
  </footer>

  {{ 'script.js' | asset_url | script_tag }}

</body>
</html>
