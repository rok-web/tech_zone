<!-- Collection Page -->
<div class="section">
  <div class="section-title">{{ collection.title }}</div>
  {% if collection.description != blank %}
    <p class="section-sub">{{ collection.description }}</p>
  {% endif %}

  <div class="features-grid">
    {% for product in collection.products %}
      <a href="{{ product.url }}" style="text-decoration:none;">
        <div class="feat-card" style="cursor:pointer;">
          {% if product.featured_image %}
            <img src="{{ product.featured_image | img_url: '300x300', crop: 'center' }}"
                 alt="{{ product.featured_image.alt | escape }}"
                 style="width:100%; border-radius:12px; margin-bottom:14px; aspect-ratio:1; object-fit:cover;">
          {% endif %}
          <div class="feat-title">{{ product.title }}</div>
          <div class="feat-desc" style="margin-top:8px; color:var(--orange2); font-weight:700;">
            {{ product.price | money }}
            {% if product.compare_at_price > product.price %}
              <span style="color:#555; text-decoration:line-through; font-weight:400; font-size:12px; margin-left:8px;">{{ product.compare_at_price | money }}</span>
            {% endif %}
          </div>
        </div>
      </a>
    {% endfor %}
  </div>
</div>
