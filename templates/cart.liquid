<!-- Cart Page -->
<div class="section">
  <div class="section-title">Your <span>Cart</span></div>

  {% if cart.item_count == 0 %}
    <p class="section-sub">Your cart is empty. <a href="/collections/all" style="color: var(--orange);">Continue shopping</a></p>
  {% else %}
    {% for item in cart.items %}
      <div style="display:flex; align-items:center; gap:20px; padding:20px 0; border-bottom:1px solid var(--border);">
        <img src="{{ item.image | img_url: '100x100' }}" alt="{{ item.title | escape }}" style="border-radius:12px; width:80px; height:80px; object-fit:cover;">
        <div style="flex:1;">
          <div style="font-weight:700; color:var(--white); margin-bottom:4px;">{{ item.title }}</div>
          <div style="font-size:13px; color:var(--muted);">{{ item.variant_title }}</div>
          <div style="font-size:13px; color:var(--orange2); margin-top:4px;">{{ item.price | money }} × {{ item.quantity }}</div>
        </div>
        <div style="font-weight:700; color:var(--white);">{{ item.line_price | money }}</div>
      </div>
    {% endfor %}

    <div style="margin-top:30px; text-align:right;">
      <div style="font-size:20px; font-weight:700; color:var(--white); margin-bottom:20px;">
        Total: {{ cart.total_price | money }}
      </div>
      <form action="/cart" method="post">
        <button type="submit" name="checkout" class="btn-primary" style="width:auto; display:inline-flex;">
          Proceed to Checkout
        </button>
      </form>
    </div>
  {% endif %}
</div>
