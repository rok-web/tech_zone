{% comment %}
  product.landing.liquid
  Premium One-Product Landing Page — Earbuds
  Drop this file in /templates/ and assign it to your product in Shopify Admin.
{% endcomment %}

<style>
  /* ── Reset & Base ─────────────────────────────── */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg-deep:     #080a0f;
    --bg-card:     #0d1017;
    --bg-raised:   #111620;
    --border:      rgba(255,255,255,0.07);
    --accent:      #00e5ff;
    --accent2:     #7c3aed;
    --gold:        #f5c842;
    --text-primary:#f0f4ff;
    --text-muted:  #7a8499;
    --grad-btn:    linear-gradient(135deg, #00e5ff 0%, #7c3aed 100%);
    --grad-hero:   radial-gradient(ellipse 80% 60% at 50% 0%, rgba(0,229,255,.12) 0%, transparent 70%);
    --shadow-glow: 0 0 40px rgba(0,229,255,.18);
    --radius:      14px;
    --font-display:'Syne', sans-serif;
    --font-body:   'DM Sans', sans-serif;
  }

  @import url('https://fonts.googleapis.com/css2?family=Syne:wght@600;700;800&family=DM+Sans:wght@300;400;500&display=swap');

  html { scroll-behavior: smooth; font-size: 16px; }

  body {
    background: var(--bg-deep);
    color: var(--text-primary);
    font-family: var(--font-body);
    font-weight: 400;
    line-height: 1.6;
    overflow-x: hidden;
  }

  h1,h2,h3,h4 { font-family: var(--font-display); line-height: 1.15; }

  a { color: inherit; text-decoration: none; }

  img { display: block; max-width: 100%; }

  .container {
    width: min(1140px, 94vw);
    margin: 0 auto;
  }

  .section { padding: 96px 0; }

  .section-label {
    font-size: .72rem;
    font-weight: 500;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 14px;
  }

  .section-title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    margin-bottom: 18px;
  }

  .section-sub {
    color: var(--text-muted);
    font-size: 1.05rem;
    max-width: 540px;
  }

  /* ── Announcement Bar ─────────────────────────── */
  .ann-bar {
    background: linear-gradient(90deg, var(--accent2) 0%, var(--accent) 100%);
    text-align: center;
    padding: 10px 16px;
    font-size: .82rem;
    font-weight: 500;
    letter-spacing: .06em;
  }

  /* ── Sticky Nav ───────────────────────────────── */
  .site-nav {
    position: sticky; top: 0; z-index: 900;
    background: rgba(8,10,15,.88);
    backdrop-filter: blur(18px);
    border-bottom: 1px solid var(--border);
    padding: 18px 0;
    transition: box-shadow .3s;
  }
  .site-nav.scrolled { box-shadow: 0 2px 30px rgba(0,0,0,.6); }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }

  .nav-logo {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.3rem;
    letter-spacing: -.01em;
  }
  .nav-logo span { color: var(--accent); }

  .nav-links {
    display: flex;
    gap: 32px;
    list-style: none;
    font-size: .9rem;
    color: var(--text-muted);
  }
  .nav-links a:hover { color: var(--text-primary); }

  .nav-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--grad-btn);
    color: #fff;
    font-weight: 600;
    font-size: .88rem;
    padding: 10px 22px;
    border-radius: 50px;
    transition: opacity .2s, transform .2s;
    border: none;
    cursor: pointer;
    white-space: nowrap;
  }
  .nav-cta:hover { opacity: .88; transform: translateY(-1px); }

  /* ── HERO ─────────────────────────────────────── */
  .hero {
    position: relative;
    padding: 100px 0 80px;
    background: var(--grad-hero);
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle 600px at 70% 50%, rgba(124,58,237,.09), transparent),
      url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.02'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
    pointer-events: none;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 60px;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(0,229,255,.08);
    border: 1px solid rgba(0,229,255,.2);
    border-radius: 50px;
    padding: 6px 16px;
    font-size: .78rem;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 22px;
    font-weight: 600;
  }

  .hero-title {
    font-size: clamp(2.4rem, 5vw, 3.8rem);
    font-weight: 800;
    line-height: 1.08;
    letter-spacing: -.02em;
    margin-bottom: 20px;
  }
  .hero-title em {
    font-style: normal;
    background: var(--grad-btn);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-desc {
    color: var(--text-muted);
    font-size: 1.05rem;
    max-width: 460px;
    margin-bottom: 32px;
  }

  .hero-price-row {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 32px;
  }

  .price-current {
    font-family: var(--font-display);
    font-size: 2.2rem;
    font-weight: 700;
    background: var(--grad-btn);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .price-compare {
    font-size: 1.1rem;
    color: var(--text-muted);
    text-decoration: line-through;
  }

  .price-save {
    background: rgba(245,200,66,.12);
    border: 1px solid rgba(245,200,66,.3);
    color: var(--gold);
    font-size: .78rem;
    font-weight: 600;
    padding: 4px 12px;
    border-radius: 50px;
    letter-spacing: .06em;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    background: var(--grad-btn);
    color: #fff;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.05rem;
    padding: 17px 42px;
    border-radius: 50px;
    border: none;
    cursor: pointer;
    transition: transform .25s, box-shadow .25s, opacity .25s;
    box-shadow: 0 8px 32px rgba(0,229,255,.22);
    letter-spacing: .02em;
  }
  .btn-primary:hover {
    transform: translateY(-3px) scale(1.02);
    box-shadow: 0 16px 48px rgba(0,229,255,.34);
  }
  .btn-primary:active { transform: translateY(0) scale(.98); }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: transparent;
    border: 1px solid var(--border);
    color: var(--text-primary);
    font-size: .95rem;
    font-weight: 500;
    padding: 16px 30px;
    border-radius: 50px;
    cursor: pointer;
    transition: border-color .2s, background .2s;
  }
  .btn-secondary:hover {
    border-color: var(--accent);
    background: rgba(0,229,255,.05);
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  .hero-trust {
    display: flex;
    align-items: center;
    gap: 24px;
    margin-top: 36px;
    padding-top: 28px;
    border-top: 1px solid var(--border);
  }

  .trust-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: .82rem;
    color: var(--text-muted);
  }
  .trust-item svg { color: var(--accent); flex-shrink: 0; }

  /* ── Product Image ────────────────────────────── */
  .hero-image-wrap {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-image-glow {
    position: absolute;
    width: 70%;
    height: 70%;
    background: radial-gradient(circle, rgba(0,229,255,.18) 0%, transparent 70%);
    border-radius: 50%;
    filter: blur(40px);
    animation: pulseGlow 4s ease-in-out infinite;
  }

  @keyframes pulseGlow {
    0%,100% { opacity: .6; transform: scale(1); }
    50%      { opacity: 1;  transform: scale(1.08); }
  }

  .hero-img {
    position: relative;
    z-index: 1;
    border-radius: 24px;
    box-shadow: 0 24px 80px rgba(0,0,0,.6), 0 0 0 1px var(--border);
    animation: floatImg 6s ease-in-out infinite;
    width: 100%;
    max-width: 480px;
    object-fit: cover;
    aspect-ratio: 1 / 1;
  }

  @keyframes floatImg {
    0%,100% { transform: translateY(0); }
    50%     { transform: translateY(-14px); }
  }

  .img-badge {
    position: absolute;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 10px 16px;
    font-size: .8rem;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 8px;
    box-shadow: 0 8px 24px rgba(0,0,0,.4);
    z-index: 2;
    backdrop-filter: blur(10px);
    animation: floatImg 6s ease-in-out infinite;
  }
  .img-badge.left  { bottom: 10%; left: -10%; animation-delay: -2s; }
  .img-badge.right { top: 12%; right: -6%; animation-delay: -4s; }

  .badge-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: #22c55e;
    box-shadow: 0 0 8px rgba(34,197,94,.6);
  }

  /* ── Stats Bar ────────────────────────────────── */
  .stats-bar {
    background: var(--bg-card);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: 36px 0;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 8px;
    text-align: center;
  }

  .stat-item { padding: 0 20px; }
  .stat-item + .stat-item { border-left: 1px solid var(--border); }

  .stat-num {
    font-family: var(--font-display);
    font-size: 2.2rem;
    font-weight: 800;
    background: var(--grad-btn);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1.1;
  }

  .stat-label {
    font-size: .82rem;
    color: var(--text-muted);
    margin-top: 4px;
  }

  /* ── Features ─────────────────────────────────── */
  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-top: 56px;
  }

  .feature-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 32px 28px;
    transition: border-color .3s, transform .3s, box-shadow .3s;
    position: relative;
    overflow: hidden;
  }
  .feature-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: var(--grad-btn);
    opacity: 0;
    transition: opacity .3s;
  }
  .feature-card:hover {
    border-color: rgba(0,229,255,.25);
    transform: translateY(-6px);
    box-shadow: 0 20px 48px rgba(0,0,0,.4);
  }
  .feature-card:hover::before { opacity: 1; }

  .feature-icon {
    width: 52px; height: 52px;
    background: linear-gradient(135deg, rgba(0,229,255,.12), rgba(124,58,237,.12));
    border: 1px solid rgba(0,229,255,.18);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
    font-size: 1.4rem;
  }

  .feature-title {
    font-size: 1.05rem;
    font-weight: 700;
    margin-bottom: 10px;
  }

  .feature-desc { color: var(--text-muted); font-size: .9rem; line-height: 1.65; }

  /* ── Product Deep-Dive ────────────────────────── */
  .deep-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 72px;
  }

  .deep-img {
    border-radius: 20px;
    box-shadow: 0 24px 64px rgba(0,0,0,.5), 0 0 0 1px var(--border);
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
  }

  .check-list { list-style: none; margin-top: 28px; display: flex; flex-direction: column; gap: 14px; }

  .check-item {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    font-size: .95rem;
  }

  .check-icon {
    flex-shrink: 0;
    width: 22px; height: 22px;
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 1px;
  }
  .check-icon svg { width: 12px; height: 12px; stroke: #fff; }

  /* ── Specs ────────────────────────────────────── */
  .specs-section { background: var(--bg-card); }

  .specs-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    margin-top: 52px;
    border: 1px solid var(--border);
  }

  .spec-row {
    background: var(--bg-raised);
    padding: 20px 28px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    transition: background .2s;
  }
  .spec-row:hover { background: rgba(0,229,255,.04); }

  .spec-key { color: var(--text-muted); font-size: .9rem; }
  .spec-val { font-weight: 600; font-size: .95rem; text-align: right; }

  /* ── Reviews ──────────────────────────────────── */
  .reviews-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-top: 56px;
  }

  .review-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 28px;
    transition: transform .3s, box-shadow .3s;
  }
  .review-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 16px 40px rgba(0,0,0,.35);
  }

  .stars { color: var(--gold); font-size: 1rem; letter-spacing: 2px; margin-bottom: 14px; }

  .review-text {
    font-size: .92rem;
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: 20px;
    font-style: italic;
  }

  .reviewer {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .reviewer-avatar {
    width: 40px; height: 40px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--accent2), var(--accent));
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: .9rem;
    color: #fff;
    flex-shrink: 0;
  }

  .reviewer-name { font-weight: 600; font-size: .88rem; }
  .reviewer-meta { font-size: .78rem; color: var(--text-muted); }

  .verified-badge {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: .72rem;
    color: #22c55e;
    font-weight: 500;
    margin-top: 2px;
  }

  /* ── Trust Badges Row ─────────────────────────── */
  .trust-section {
    background: var(--bg-card);
    padding: 60px 0;
  }

  .trust-badges {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 40px;
    flex-wrap: wrap;
  }

  .trust-badge {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px 24px;
    background: var(--bg-raised);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    min-width: 200px;
    transition: border-color .3s;
  }
  .trust-badge:hover { border-color: rgba(0,229,255,.25); }

  .trust-badge-icon { font-size: 1.6rem; flex-shrink: 0; }
  .trust-badge-text strong { display: block; font-size: .9rem; font-weight: 600; }
  .trust-badge-text span { font-size: .78rem; color: var(--text-muted); }

  /* ── FAQ ──────────────────────────────────────── */
  .faq-list { margin-top: 52px; display: flex; flex-direction: column; gap: 12px; max-width: 780px; }

  .faq-item {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
  }

  .faq-q {
    width: 100%;
    background: none;
    border: none;
    color: var(--text-primary);
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 600;
    padding: 22px 28px;
    text-align: left;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    transition: background .2s;
  }
  .faq-q:hover { background: rgba(255,255,255,.03); }

  .faq-chevron {
    flex-shrink: 0;
    width: 20px; height: 20px;
    border-radius: 50%;
    border: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform .3s, background .3s;
    font-size: .7rem;
  }
  .faq-item.open .faq-chevron {
    transform: rotate(180deg);
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    border-color: transparent;
  }

  .faq-a {
    max-height: 0;
    overflow: hidden;
    transition: max-height .4s ease, padding .4s ease;
    padding: 0 28px;
    color: var(--text-muted);
    font-size: .93rem;
    line-height: 1.7;
  }
  .faq-item.open .faq-a { max-height: 300px; padding: 0 28px 22px; }

  /* ── CTA Banner ───────────────────────────────── */
  .cta-banner {
    position: relative;
    padding: 100px 0;
    overflow: hidden;
    text-align: center;
  }
  .cta-banner::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 70% 70% at 50% 50%, rgba(0,229,255,.1) 0%, transparent 70%),
      radial-gradient(ellipse 40% 60% at 30% 50%, rgba(124,58,237,.08) 0%, transparent 70%);
    pointer-events: none;
  }

  .cta-title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    margin-bottom: 16px;
  }

  .cta-sub {
    color: var(--text-muted);
    font-size: 1.05rem;
    max-width: 500px;
    margin: 0 auto 36px;
  }

  .cta-price-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
    margin-bottom: 32px;
  }

  /* ── Footer ───────────────────────────────────── */
  .site-footer {
    background: var(--bg-card);
    border-top: 1px solid var(--border);
    padding: 48px 0 32px;
    text-align: center;
  }

  .footer-logo {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 800;
    margin-bottom: 16px;
  }
  .footer-logo span { color: var(--accent); }

  .footer-links {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 28px;
    flex-wrap: wrap;
    list-style: none;
    font-size: .85rem;
    color: var(--text-muted);
    margin-bottom: 24px;
  }
  .footer-links a:hover { color: var(--text-primary); }

  .footer-copy {
    font-size: .8rem;
    color: var(--text-muted);
  }

  /* ── WhatsApp Floating ────────────────────────── */
  .wa-btn {
    position: fixed;
    bottom: 28px; right: 28px;
    z-index: 999;
    width: 58px; height: 58px;
    background: #25d366;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 6px 24px rgba(37,211,102,.4);
    transition: transform .25s, box-shadow .25s;
    cursor: pointer;
    text-decoration: none;
  }
  .wa-btn:hover {
    transform: translateY(-4px) scale(1.06);
    box-shadow: 0 12px 36px rgba(37,211,102,.5);
  }
  .wa-btn svg { width: 28px; height: 28px; fill: #fff; }

  /* ── Scroll-reveal ────────────────────────────── */
  .reveal {
    opacity: 0;
    transform: translateY(32px);
    transition: opacity .7s ease, transform .7s ease;
  }
  .reveal.visible {
    opacity: 1;
    transform: none;
  }

  /* ── Responsive ───────────────────────────────── */
  @media (max-width: 900px) {
    .hero-grid, .deep-grid { grid-template-columns: 1fr; }
    .hero-grid { text-align: center; }
    .hero-desc, .hero-actions { margin-left: auto; margin-right: auto; justify-content: center; }
    .hero-trust { justify-content: center; flex-wrap: wrap; }
    .hero-price-row { justify-content: center; }
    .hero-image-wrap { order: -1; }
    .img-badge.left  { left: 0; }
    .img-badge.right { right: 0; }
    .features-grid, .reviews-grid { grid-template-columns: 1fr 1fr; }
    .stats-grid { grid-template-columns: repeat(2, 1fr); gap: 1px; background: var(--border); }
    .stat-item + .stat-item { border-left: none; }
    .stat-item { background: var(--bg-deep); }
    .specs-grid { grid-template-columns: 1fr; }
